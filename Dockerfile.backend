FROM node:18-alpine

ARG BACKEND_PORT
ARG VITE_REQUIRED_PIN
ARG VITE_ADMIN_PIN
ARG GOOGLE_CLIENT_ID
ARG GOOGLE_CLIENT_SECRET
ARG FRONTEND_URL
ARG mongo
ARG ENCRYPTION_KEY
ARG SESSION_SECRET
ARG ALLOWED_IPS
ARG SMTP_HOST
ARG SMTP_PORT
ARG SMTP_USER
ARG SMTP_PASSWORD
ARG SMTP_FROM_NAME
ARG SMTP_FROM_EMAIL
ARG PORT
ARG NODE_ENV
ARG REDIS_HOST

WORKDIR /app

COPY package*.json ./

RUN npm ci && npm cache clean --force

COPY . .

ENV PORT=7002
EXPOSE $PORT

CMD ["npx", "tsx", "api/server.ts"]
